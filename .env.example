# yandex2mqtt configuration — copy to .env for local dev.
#
# In production these values are rendered from Ansible Vault into the container
# environment; nothing secret is ever committed. Keep .env out of git.

# --- MQTT broker ---
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# --- Web server ---
WEB_PORT=80
# TLS is required unless WEB_BEHIND_PROXY=true (proxy terminates TLS).
WEB_BEHIND_PROXY=false
WEB_TLS_KEY=/app/cert/key.pem
WEB_TLS_CERT=/app/cert/fullchain.pem

# --- Session ---
# Generate a strong random value, e.g. `openssl rand -hex 32`.
SESSION_SECRET=change-me

# --- Local admin user ---
ADMIN_ID=1
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_NAME=Administrator

# --- OAuth client (Yandex) ---
OAUTH_CLIENT_DBID=1
OAUTH_CLIENT_ID=yandex_smarthome
OAUTH_CLIENT_SECRET=change-me
OAUTH_CLIENT_NAME=Yandex
OAUTH_CLIENT_TRUSTED=false

# --- Yandex state notifications (optional) ---
YANDEX_SKILL_ID=
YANDEX_OAUTH_TOKEN=
# Defaults to ADMIN_ID when empty.
YANDEX_USER_ID=

# --- Storage ---
DB_PATH=./data/yandex2mqtt.db
DEVICES_FILE=./data/devices.yaml

# --- Logging ---
LOG_LEVEL=info
