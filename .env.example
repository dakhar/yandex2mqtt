# yandex2mqtt configuration — copy to .env for local dev.
#
# In production these values are rendered from Ansible Vault into the container
# environment; nothing secret is ever committed. Keep .env out of git.

# --- Reverse proxy (nginx-proxy + letsencrypt companion) ---
# Consumed by the proxy stack, not by the app itself.
VIRTUAL_HOST=your.domain.example
VIRTUAL_PORT=80
LETSENCRYPT_HOST=your.domain.example
# Host path mounted as /app/data (device catalog + SQLite DB).
DATA_DIR=./data

# --- MQTT broker ---
# The initial connection; an admin can override host/port/creds in the UI
# (Settings -> Servers), stored in the DB.
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# --- openHAB (optional second transport) ---
# Enable by setting URL + a token. Prefer OPENHAB_TOKEN_FILE (a mounted secret)
# over OPENHAB_TOKEN. Overridable in the UI (Settings -> Servers).
OPENHAB_URL=
OPENHAB_TOKEN=
OPENHAB_TOKEN_FILE=

# --- Web server ---
WEB_PORT=80
# TLS is required unless WEB_BEHIND_PROXY=true (proxy terminates TLS).
WEB_BEHIND_PROXY=false
# External base URL for building the video_stream proxy link. Set this when the
# reverse proxy doesn't preserve the Host header, else camera stream URLs point
# at the internal address. e.g. https://yahome.bels.pw
# PUBLIC_URL=
WEB_TLS_KEY=/app/cert/key.pem
WEB_TLS_CERT=/app/cert/fullchain.pem

# --- Session ---
# Generate a strong random value, e.g. `openssl rand -hex 32`.
SESSION_SECRET=change-me

# --- Local admin user ---
ADMIN_ID=1
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_NAME=Administrator

# --- OAuth client (Yandex) ---
OAUTH_CLIENT_DBID=1
OAUTH_CLIENT_ID=yandex_smarthome
OAUTH_CLIENT_SECRET=change-me
OAUTH_CLIENT_NAME=Yandex
OAUTH_CLIENT_TRUSTED=false

# --- Yandex state notifications (optional) ---
YANDEX_SKILL_ID=
YANDEX_OAUTH_TOKEN=
# Defaults to ADMIN_ID when empty.
YANDEX_USER_ID=

# --- Storage ---
DB_PATH=./data/yandex2mqtt.db
DEVICES_FILE=./data/devices.yaml

# --- Logging ---
LOG_LEVEL=info
